parameters:
    bootstrapFiles:
        - phpstan.autoload.inc.php
    excludePaths:
        - ../src/*/Tests/*
    ignoreErrors:
        -
            message: '#uninitialized readonly property \$escaper#'
            paths:
                - ../src/Lunr/Gravity/MySQL/MySQLConnection.php
                - ../src/Lunr/Gravity/SQLite3/SQLite3Connection.php
